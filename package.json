{
  "name": "envrizz",
  "version": "3.3.1",
  "description": "Give your .env files that rizz - sync them with AWS Secrets Manager",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "envrizz": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest --passWithNoTests",
    "lint": "eslint .",
    "prepare": "husky",
    "prepack": "npm pkg delete scripts.build scripts.dev scripts.test scripts.lint scripts.prepare scripts.prepack scripts.postpack devDependencies overrides",
    "postpack": "git checkout -- package.json"
  },
  "keywords": [
    "env",
    "aws",
    "secrets",
    "sync",
    "environment"
  ],
  "author": "Terrance MacGregor",
  "repository": {
    "type": "git",
    "url": "https://github.com/terrancemacgregor/envrizz.git"
  },
  "bugs": {
    "url": "https://github.com/terrancemacgregor/envrizz/issues"
  },
  "homepage": "https://github.com/terrancemacgregor/envrizz#readme",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.400.0",
    "@aws-sdk/credential-provider-sso": "^3.400.0"
  },
  "dependencies": {
    "commander": "^11.0.0",
    "dotenv": "^16.3.1"
  },
  "overrides": {
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.2",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.0",
    "typescript-eslint": "^8.59.3"
  }
}
